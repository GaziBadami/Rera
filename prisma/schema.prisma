  source_file      String?   @db.VarChar(255)
  scraped_at       DateTime? @default(now()) @db.Timestamp(0)
}

model bihar_interim_orders {
  id               Int       @id @default(autoincrement())
  notice_date      String?   @db.VarChar(50)
  case_no          String?   @db.VarChar(100)
  complainant      String?   @db.Text
  respondent       String?   @db.Text
  full_description String?   @db.Text
  pdf_filename     String?   @db.VarChar(255)
  scraped_at       DateTime? @default(now()) @db.Timestamp(0)
}

model bihar_projects {
  registration_no   String  @id @db.VarChar(255)
  project_name      String? @db.VarChar(500)
  promoter_name     String? @db.VarChar(500)
  project_address   String? @db.Text
