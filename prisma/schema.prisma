generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model andaman_agents {
  id                    Int     @id @default(autoincrement())
  sl_no                 Int?
  registration_no       String? @db.Text
  agent_name            String? @db.Text
  agent_address         String? @db.Text
  individual_firm       String? @db.VarChar(50)
  registration_validity String? @db.VarChar(50)
  renewal               String? @db.VarChar(50)

  @@index([registration_validity], map: "idx_validity")
}

model andaman_projects {
  id                      Int       @id @default(autoincrement())
  sl_no                   Int?
  project_registration_no String?   @db.Text
  applicant_name_address  String?   @db.Text
  project_details_address String?   @db.Text
  approval_details        String?   @db.Text
  project_completion_date String?   @db.Text
  other_details           String?   @db.Text
  approval_pdf_url        String?   @db.Text
  approval_pdf_filename   String?   @db.VarChar(255)
  carpet_pdf_url          String?   @db.Text
  carpet_pdf_filename     String?   @db.VarChar(255)
  progress_pdf_url        String?   @db.Text
  progress_pdf_filename   String?   @db.VarChar(255)
  current_status          String?   @db.Text
  scraped_at              DateTime? @db.DateTime(0)

  @@index([project_registration_no(length: 100)], map: "idx_reg_no")
}

model ap_agents {
  id                 Int     @id @default(autoincrement())
  serial_no          Int?
  registration_id    String? @unique(map: "registration_id") @db.VarChar(60)
  name               String? @db.Text
  place              String? @db.Text
  date_of_submission String? @db.VarChar(100)
  date_of_approval   String? @db.VarChar(100)
  valid_till         String? @db.VarChar(100)

  @@index([registration_id], map: "idx_reg_id")
  @@index([valid_till], map: "idx_valid_till")
}

model ap_complaint_orders {
  id             Int     @id @default(autoincrement())
  complaint_no   String? @db.Text
  complaint_date String? @db.VarChar(50)
  pdf_url        String? @db.Text
  pdf_filename   String? @db.VarChar(255)
  pdf_size_kb    Int?

  @@index([complaint_date], map: "idx_date")
}

model ap_project {
  id                     Int       @id @default(autoincrement())
  serial_no              Int?
  aprera_registration_id String?   @unique(map: "aprera_registration_id") @db.VarChar(60)
  project_name           String?   @db.Text
  place                  String?   @db.Text
  project_type           String?   @db.VarChar(100)
  status                 String?   @db.VarChar(100)
  date_of_approval       String?   @db.VarChar(100)
  expected_completion    String?   @db.VarChar(100)
  imported_at            DateTime? @db.DateTime(0)

  @@index([aprera_registration_id], map: "idx_reg_id")
  @@index([status], map: "idx_status")
  @@index([project_type], map: "idx_type")
}

model ap_projects {
  id                     Int       @id @default(autoincrement())
  serial_no              Int?
  aprera_registration_id String?   @unique(map: "aprera_registration_id") @db.VarChar(60)
  project_name           String?   @db.Text
  place                  String?   @db.Text
  project_type           String?   @db.VarChar(100)
  status                 String?   @db.VarChar(50)
  date_of_approval       String?   @db.VarChar(20)
  expected_completion    String?   @db.VarChar(20)
  imported_at            DateTime? @db.DateTime(0)

  @@index([aprera_registration_id], map: "idx_reg_id")
  @@index([status], map: "idx_status")
  @@index([project_type], map: "idx_type")
}

model approved_agents {
  id                         Int       @id @default(autoincrement())
  sr_no                      String?   @db.VarChar(50)
  agent_ack_no               String?   @db.VarChar(200)
  agent_reg_no               String    @unique(map: "agent_reg_no") @db.VarChar(200)
  agent_name                 String    @db.VarChar(500)
  agent_address              String?   @db.Text
  agent_district             String?   @db.VarChar(100)
  fee_paid                   String?   @db.VarChar(50)
  registration_approved_date DateTime? @db.Date
  registration_expire_date   DateTime? @db.Date
  agent_type                 String?   @db.VarChar(50)
  agent_mobile_no            String?   @db.VarChar(20)
  agent_email_id             String?   @db.VarChar(255)
  agent_pan_no               String?   @db.VarChar(50)
  status                     String?   @db.VarChar(50)
  created_on                 DateTime? @db.DateTime(0)
  submission_date            DateTime? @db.DateTime(0)
  renewal_date               DateTime? @db.DateTime(0)
  scraped_at                 DateTime? @db.DateTime(0)
  created_at                 DateTime? @default(now()) @db.Timestamp(0)
  updated_at                 DateTime? @default(now()) @db.Timestamp(0)

  @@index([agent_name(length: 255)], map: "idx_agent_name")
  @@index([agent_reg_no], map: "idx_agent_reg_no")
  @@index([agent_district], map: "idx_district")
  @@index([scraped_at], map: "idx_scraped_at")
  @@index([status], map: "idx_status")
}

model approved_projects {
  id                       Int       @id @default(autoincrement())
  sr_no                    String?   @db.VarChar(50)
  project_name             String    @db.VarChar(500)
  project_address          String?   @db.Text
  project_type             String?   @db.VarChar(100)
  promoter_name            String?   @db.VarChar(300)
  email_id                 String?   @db.VarChar(255)
  mobile_no                String?   @db.VarChar(20)
  project_registration_no  String    @unique(map: "project_registration_no") @db.VarChar(200)
  project_registration_url String?   @db.Text
  scraped_at               DateTime? @db.DateTime(0)
  created_at               DateTime? @default(now()) @db.Timestamp(0)
  updated_at               DateTime? @default(now()) @db.Timestamp(0)

  @@index([project_name(length: 255)], map: "idx_project_name")
  @@index([promoter_name(length: 255)], map: "idx_promoter_name")
  @@index([project_registration_no], map: "idx_registration_no")
  @@index([scraped_at], map: "idx_scraped_at")
}

model assam_agents {
  id                   Int       @id @default(autoincrement())
  serial_no            Int?
  registration_cert_no String?   @unique(map: "registration_cert_no") @db.VarChar(60)
  agent_name           String?   @db.Text
  district             String?   @db.VarChar(100)
  category             String?   @db.VarChar(50)
  cert_issuing_date    String?   @db.VarChar(20)
  cert_expiry_date     String?   @db.VarChar(20)
  certificate_pdf_url  String?   @db.Text
  pdf_filename         String?   @db.VarChar(255)
  pdf_size_kb          Int?
  download_status      String?   @db.VarChar(50)
  downloaded_at        DateTime? @db.DateTime(0)

  @@index([district], map: "idx_district")
  @@index([registration_cert_no], map: "idx_reg_cert")
  @@index([download_status], map: "idx_status")
}

model assam_orders {
  id              Int       @id @default(autoincrement())
  title_header    String?   @db.Text
  date_of_order   String?   @db.VarChar(50)
  file_no         String?   @db.VarChar(100)
  pdf_url         String?   @db.Text
  pdf_filename    String?   @db.VarChar(255)
  pdf_size_kb     Int?
  download_status String?   @db.VarChar(50)
  scraped_at      DateTime? @db.DateTime(0)

  @@index([date_of_order], map: "idx_date")
  @@index([file_no], map: "idx_file_no")
}

model assam_projects {
  id            Int       @id @default(autoincrement())
  serial_no     Int?
  reg_cert_no   String?   @unique(map: "reg_cert_no") @db.VarChar(100)
  project_name  String?   @db.Text
  promoter      String?   @db.Text
  location      String?   @db.Text
  district      String?   @db.VarChar(100)
  cert_pdf      String?   @db.Text
  occupancy_pdf String?   @db.Text
  qpr_pdf       String?   @db.Text
  progress_pdf  String?   @db.Text
  downloaded    Int?      @default(0)
  imported_at   DateTime? @db.DateTime(0)
}

model assam_registered_projects {
  id                          Int     @id @default(autoincrement())
  serial_no                   Int?
  registration_cert_number    String? @db.VarChar(100)
  project_name                String? @db.Text
  promoter                    String? @db.Text
  project_location            String? @db.Text
  project_district            String? @db.VarChar(100)
  webpage_pdf_url             String? @db.Text
  certificate_pdf_url         String? @db.Text
  certificate_pdf_filename    String? @db.VarChar(255)
  occupancy_pdf_url           String? @db.Text
  occupancy_pdf_filename      String? @db.VarChar(255)
  qpr_cumulative_pdf_url      String? @db.Text
  qpr_cumulative_pdf_filename String? @db.VarChar(255)
  qpr_quarterly_pdf_url       String? @db.Text

  @@index([registration_cert_number], map: "idx_cert_no")
}

model bihar_defaulters {
  id               Int       @id @default(autoincrement())
  defaulter_type   String?   @db.Text
  sl_no            String?   @db.Text
  promoter_name    String?   @db.Text
  promoter_address String?   @db.Text
