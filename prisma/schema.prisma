  extended_end_date   String?   @db.VarChar(50)
  website_url         String?   @db.Text
  certificate_status  String?   @db.VarChar(50)
  page_number         Int?
  raw_reg_text        String?   @db.Text
  scraped_at          DateTime? @db.DateTime(0)

  @@index([district], map: "idx_district")
  @@index([registration_number], map: "idx_reg")
}

model complaints {
  id           Int     @id @default(autoincrement())
  complaint_no String? @db.VarChar(255)
  complainant  String? @db.Text
  respondent   String? @db.Text
  status       String? @db.VarChar(255)
  pdf_link     String? @db.Text
}

model complaints_district_wise {
  id             Int       @id @default(autoincrement())
  complaint_type String    @unique(map: "complaint_type") @db.VarChar(200)
  ahmedabad      Int?      @default(0)
  vadodara       Int?      @default(0)
  surat          Int?      @default(0)
  rajkot         Int?      @default(0)
  gandhinagar    Int?      @default(0)
  bhavnagar      Int?      @default(0)
  valsad         Int?      @default(0)
  others         Int?      @default(0)
  total          Int?      @default(0)
  scraped_at     DateTime? @db.DateTime(0)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @db.Timestamp(0)

  @@index([complaint_type], map: "idx_complaint_type")
  @@index([scraped_at], map: "idx_scraped_at")
}

model complaints_summary {
  id             Int       @id @default(autoincrement())
  complaint_type String    @db.VarChar(200)
  district_name  String?   @db.VarChar(100)
  request_count  Int?      @default(0)
  form_type      String?   @db.VarChar(100)
  soumoto_case   String?   @db.VarChar(50)
  scraped_at     DateTime? @db.DateTime(0)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @db.Timestamp(0)

  @@unique([complaint_type, district_name, form_type], map: "unique_complaint")
  @@index([complaint_type], map: "idx_complaint_type")
  @@index([district_name], map: "idx_district")
  @@index([form_type], map: "idx_form_type")
  @@index([scraped_at], map: "idx_scraped_at")
}

