model bihar_registered_agents {
  registration_no   String    @id @db.VarChar(100)
  agent_name        String?   @db.VarChar(255)
  district          String?   @db.VarChar(100)
  registration_date String?   @db.VarChar(50)
  mobile_no         String?   @db.VarChar(20)
  qr_content        String?   @db.Text
  pdf_path          String?   @db.Text
  scraped_at        DateTime? @default(now()) @db.Timestamp(0)
}

model chhattisgarh_agents {
  id                  Int     @id @default(autoincrement())
  sn                  Int?
  name                String? @db.VarChar(500)
  agent_type          String? @db.VarChar(100)
  registration_no     String? @unique(map: "registration_no") @db.VarChar(100)
  district            String? @db.VarChar(200)
  tehsil              String? @db.VarChar(200)
  validity_period     String? @db.VarChar(200)
  extended_validity   String? @db.VarChar(100)
  registration_status String? @db.VarChar(50)
  profile_url         String? @db.Text

  @@index([district], map: "idx_district")
  @@index([registration_no], map: "idx_reg")
  @@index([registration_status], map: "idx_status")
}

model chhattisgarh_defaulters {
  id                      Int       @id @default(autoincrement())
  sn                      Int?
  promoter_name           String?   @db.Text
  project_name            String?   @db.VarChar(500)
  registration_number     String?   @db.VarChar(100)
  district                String?   @db.VarChar(200)
  tehsil                  String?   @db.VarChar(200)
  defaulter_approval_date String?   @db.VarChar(50)
  has_registration        Boolean?  @default(true)
  page_number             Int?
  scraped_at              DateTime? @db.DateTime(0)

  @@index([district], map: "idx_district")
  @@index([promoter_name(length: 100)], map: "idx_promoter")
  @@index([registration_number], map: "idx_reg")
}

model chhattisgarh_final_orders {
  id                      Int       @id @default(autoincrement())
  sn                      Int?
  complaint_number        String?   @db.VarChar(200)
  complaint_link          String?   @db.Text
  applicant               String?   @db.Text
  respondent              String?   @db.Text
  project_name            String?   @db.Text
  project_registration_no String?   @db.VarChar(200)
  order_under_section     String?   @db.VarChar(500)
  order_date              String?   @db.VarChar(50)
  remark                  String?   @db.Text
  pdf_url                 String?   @db.Text
  pdf_filename            String?   @db.VarChar(500)
  pdf_size_kb             Int?
  download_status         String?   @db.VarChar(50)
  page_number             Int?
  scraped_at              DateTime? @db.DateTime(0)

  @@index([complaint_number], map: "idx_complaint")
  @@index([order_date], map: "idx_order_date")
  @@index([project_registration_no], map: "idx_reg_no")
}

model chhattisgarh_projects_complete {
  id                  Int       @id @default(autoincrement())
  sn                  Int?
  project_name        String?   @db.VarChar(500)
  registration_number String?   @db.VarChar(100)
  authorised_name     String?   @db.VarChar(500)
  promoter_name       String?   @db.Text
  project_type        String?   @db.VarChar(200)
